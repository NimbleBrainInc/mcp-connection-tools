{
  "$schema": "https://schemas.nimblebrain.ai/v1/nimblebrain-server.schema.json",
  "name": "ai.nimblebrain/connection-tools",
  "description": "MCP server registry search and integration management tools for AI agents",
  "version": "0.1.0",
  "title": "Connection Tools MCP Server",
  "repository": {
    "type": "git",
    "url": "https://github.com/NimbleBrainInc/mcp-connection-tools"
  },
  "_meta": {
    "ai.nimblebrain/v1": {
      "runtime": "python:3.13",
      "capabilities": {
        "tools": true,
        "resources": true,
        "prompts": false
      },
      "display": {
        "category": "developer-tools",
        "tags": ["registry", "integrations", "connections", "management"]
      },
      "deployment": {
        "protocol": "http",
        "port": 8080,
        "mcpPath": "/mcp"
      },
      "container": {
        "healthCheck": {
          "path": "/health",
          "port": 8080
        }
      },
      "resources": {
        "limits": {"memory": "512Mi", "cpu": "500m"},
        "requests": {"memory": "256Mi", "cpu": "100m"}
      },
      "scaling": {
        "minReplicas": 2,
        "maxReplicas": 4
      }
    }
  }
}
